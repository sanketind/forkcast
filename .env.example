# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forkcast

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ML_SERVICE_URL=http://localhost:8000

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API
# NEXT_PUBLIC_ prefix is required — these are safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supply intelligence — News ────────────────────────────────────────────────
# Get a free key at https://newsapi.org/register (500 req/day on free tier)
NEWSAPI_KEY=your_newsapi_key_here

# ── Supply intelligence — Mandi prices ───────────────────────────────────────
# data.gov.in API key for Agmarknet commodity price feed
# Register at https://data.gov.in/user/register
AGMARKNET_API_KEY=your_agmarknet_key_here

# ── WhatsApp notifications (Twilio) ──────────────────────────────────────────
# Sign up at https://www.twilio.com/en-us/messaging/channels/whatsapp
# Sandbox: "whatsapp:+14155238886" — Production: your approved WhatsApp number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Weather ───────────────────────────────────────────────────────────────────
# Free tier: 1,000 calls/day — register at https://openweathermap.org/api
# Uses 5-day/3-hour forecast endpoint. Falls back to seasonal heuristic if unset.
OPENWEATHERMAP_API_KEY=your_owm_key_here

# ── AI / LLM (optional — for higher-confidence supply signal parsing) ─────────
# If set, supply headline analysis uses GPT-4o instead of keyword matching
OPENAI_API_KEY=sk-...

# ── Inngest (background jobs) ─────────────────────────────────────────────────
# Leave blank for local dev (Inngest Dev Server handles this automatically)
# https://app.inngest.com/sign-up for production
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=
