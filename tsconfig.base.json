{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@forkcast/db": ["packages/db/src/index.ts"],
      "@forkcast/db/*": ["packages/db/src/*"],
      "@forkcast/domain": ["packages/domain/src/index.ts"],
      "@forkcast/domain/*": ["packages/domain/src/*"],
      "@forkcast/integrations": ["packages/integrations/src/index.ts"],
      "@forkcast/integrations/*": ["packages/integrations/src/*"]
    }
  }
}
